<resources xmlns:xliff="urn:oasis:names:tc:xliff:document:1.2">
    <!-- Device specific doze package -->
    <string name="config_customDozePackage" translatable="false">org.lineageos.settings.device/org.lineageos.settings.device.DozePreferenceActivity</string>

    <!-- Whether to show min/max refresh rate in display settings -->
    <bool name="config_show_refresh_rate_controls">true</bool>
    <bool name="config_supports_dynamic_refresh_rate_controls">true</bool>

    <!-- Whether device supports increased touch sensitvity -->
    <bool name="config_supportTouchPollingMode">true</bool>

    <!-- Default value for battery_light_enabled preference -->
    <bool name="def_battery_light_enabled">false</bool>
    <!-- Default value for battery light pulse -->
    <bool name="def_battery_light_pulse">false</bool>
</resources>
